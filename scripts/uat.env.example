# uat E2E 验收凭证模板。
# 用法：复制到 ~/.claude/dws-agent/uat.env，填好后 chmod 600，切勿入 git。
#   cp scripts/uat.env.example ~/.claude/dws-agent/uat.env
#   vim ~/.claude/dws-agent/uat.env && chmod 600 ~/.claude/dws-agent/uat.env
#
# ⚠ 暂用 hiqadmin 共用账号：E2E 登录/顶下线会把正在用它的真人踢下线，
#   跑前先确认无人在用、错峰执行；尽快申请 uat 专属测试账号替换。

export UAT_TEST_USER=<uat 测试账号，如 hiqadmin>
export UAT_TEST_PASSWORD=<密码>
export UAT_EDITOR_BASE=https://editor2.hiqdat.dev
export UAT_SSO_PREFIX=/api/sso
export UAT_PRODUCT_CODE=hiq_editor
