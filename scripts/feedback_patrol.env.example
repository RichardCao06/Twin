# feedback 巡检凭证模板。
# 用法：复制到 ~/.claude/dws-agent/patrol.env，填好后 chmod 600，切勿入 git。
#   cp scripts/feedback_patrol.env.example ~/.claude/dws-agent/patrol.env
#   vim ~/.claude/dws-agent/patrol.env && chmod 600 ~/.claude/dws-agent/patrol.env

export CLAUDE_CENTER_URL=http://127.0.0.1:3000
export CLAUDE_CENTER_USER=<专用 publisher 账号，别用 admin>
export CLAUDE_CENTER_PASSWORD=<密码>
# dws 真实二进制（通知曹勇用）；留空则 wrapper 自动 which dws
# export DWS_AGENT_DWS_BIN=/opt/homebrew/bin/dws
